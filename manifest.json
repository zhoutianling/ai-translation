{
  "manifest_version": 3,
  "name": "LingoTrans - AI 中英文本翻译",
  "short_name": "LingoTrans",
  "description": "使用你自己的 OpenAI 兼容 API，在侧栏中自动进行中英文本互译。",
  "version": "0.2.2",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "LingoTrans 翻译器",
    "default_popup": "ui/panel.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "ui/panel.html"
  },
  "options_page": "ui/options.html",
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
